# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google APIs
# Server-side only (used by the /api/chat route). Do NOT prefix with NEXT_PUBLIC_
# or the key will be exposed in the browser bundle.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Add other API keys here
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
