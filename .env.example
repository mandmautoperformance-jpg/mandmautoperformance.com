# M&M Auto Performance - Environment Variables

# ============================================================================
# SUPABASE (Database & Authentication)
# ============================================================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# AI & LLM APIs
# ============================================================================
# Get API key from Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxx...

# Get API key from OpenAI (GPT-4o fallback)
OPENAI_API_KEY=sk-xxx...

# ============================================================================
# VERCEL AI SDK
# ============================================================================
# Vercel AI SDK configuration (auto-configured if deploying to Vercel)
VERCEL_AI_ENABLED=true

# ============================================================================
# ADMIN & SECURITY
# ============================================================================
# Secret key for admin operations (generate with: openssl rand -base64 32)
ADMIN_SECRET_KEY=your-secure-random-key-here

# JWT Secret for custom JWT operations (if needed)
JWT_SECRET=your-jwt-secret-here

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features
NEXT_PUBLIC_ENABLE_AI_CONCIERGE=true
NEXT_PUBLIC_ENABLE_TELEMETRY=true
NEXT_PUBLIC_ENABLE_DYNAMIC_PRICING=true
NEXT_PUBLIC_ENABLE_HABIT_SCORING=true

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Google Maps API (for vehicle location mapping)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# Sentry error tracking (optional)
SENTRY_AUTH_TOKEN=sntrys_xxx...
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================================================
# SENDGRID (Email Service)
# ============================================================================
SENDGRID_API_KEY=SG.xxx...
SENDGRID_FROM_EMAIL=noreply@mandmautoperformance.com

# ============================================================================
# STRIPE (Payments - if adding payment processing)
# ============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx...
STRIPE_SECRET_KEY=sk_test_xxx...
STRIPE_WEBHOOK_SECRET=whsec_xxx...

# ============================================================================
# ANALYTICS
# ============================================================================
# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_DOMAIN=mandmautoperformance.com

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit this file with real values
# 2. Prefix NEXT_PUBLIC_ variables are exposed to browser (use for non-sensitive data)
# 3. Use Vercel dashboard for production environment variables
# 4. For local development, copy this to .env.local and fill with test values
# 5. See AGENTS.md for full documentation on each variable
